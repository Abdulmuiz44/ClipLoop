# Postgres connection string (Supabase/Postgres compatible)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cliploop

# Use demo auth fallback for local development
MOCK_MODE=true
DEMO_USER_EMAIL=demo@cliploop.local

# Use deterministic mock data generation
MOCK_LLM=true
INVITE_ONLY_MODE=true

# Optional placeholders for a future real LLM provider
LLM_PROVIDER=mock
LLM_API_KEY=

# Public app URL for billing redirects and canonical links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Lemon Squeezy billing
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_STARTER_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
