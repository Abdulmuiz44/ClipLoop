# Postgres connection string (Supabase/Postgres compatible)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cliploop

# Use demo auth fallback for local development
MOCK_MODE=true
DEMO_USER_EMAIL=cliploopapp@gmail.com

# Use deterministic mock data generation
MOCK_LLM=false
INVITE_ONLY_MODE=true

# LLM provider (Mistral default for production chat)
LLM_PROVIDER=mistral
LLM_API_KEY=
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Public app URL for billing redirects and canonical links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Instagram publishing integration (optional in local mock mode)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/integrations/instagram/callback

# Used to encrypt connected channel tokens at rest
ENCRYPTION_SECRET=

# HyperFrames renderer (optional)
HYPERFRAMES_ENABLED=false
HYPERFRAMES_BIN=hyperframes

# Lemon Squeezy billing
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_STARTER_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
